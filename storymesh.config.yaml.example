# ------
# StoryMesh Global Configuration File
# ------
# Non-secret settings that control the pipeline.
# API keys live in .env (see .env.example). This file is part of
# the code repo so that model choices, temperatures, and defaults
# are controllable and trackable over time.
#------

# ------
# LLM defaults
# ------
# These settings apply when an agent does not specify overrides.
llm:
  default_provider: anthropic
  default_model: claude-haiku-4-5-20251001
  default_max_tokens: 1024
  default_temperature: 1.0

# ------
# Per-Agent overrides
# ------
agents:
  genre_normalizer:
    provider: anthropic
    model: claude-haiku-4-5-20251001
    temperature: 0.0
    max_tokens: 1024
  book_ranker:
    top_n: 10
    llm_rerank: false
    provider: anthropic
    model: claude-haiku-4-5-20251001
    temperature: 0.0
    max_tokens: 1024
    rating_confidence_threshold: 50
    weights:
      genre_overlap: 0.40
      reader_engagement: 0.25
      rating_quality: 0.20
      rating_volume: 0.15
  proposal_draft:
    provider: anthropic
    model: claude-sonnet-4-6
    temperature: 1.0
    max_tokens: 4096

# ------
# External API Clients
# ------
api_clients:
  open_library:
    user_agent:    # Optional; "AppName (contact@email.com)" for higher rate limit
    max_books: 50  # Total cap after deduplication across all genre queries

# ------
# Caching Configuration
# ------
cache:
  dir: ~/.cache/storymesh

# ------
# Logging
# ------
logging:
  level: INFO

# ------
# LangSmith Observability (optional)
# ------
# Enable tracing: pip install "storymesh[langsmith]"
# Then set LANGCHAIN_TRACING_V2=true and LANGCHAIN_API_KEY in .env.
# The project name groups all pipeline runs in the LangSmith dashboard.
# LangGraph node spans are traced automatically; individual LLM calls are
# traced via the @_traceable decorator in storymesh.llm.base.
langsmith:
  project: storymesh-dev