# LLM Provider API keys
# Install the matching optional extra: pip install "storymesh[openai]", etc.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# External data sources
# Open Library API: No API key required. Rate limits are 1 req/sec (default)
# or 3 req/sec if a User-Agent header with app name and contact email is provided.
# See: https://openlibrary.org/developers/api
