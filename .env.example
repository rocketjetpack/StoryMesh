# LLM Provider API keys
# Install the matching optional extra: pip install "storymesh[openai]", etc.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# External data sources
# Open Library API: No API key required. Rate limits are 1 req/sec (default)
# or 3 req/sec if a User-Agent header with app name and contact email is provided.
# See: https://openlibrary.org/developers/api

# LangSmith Observability (optional)
# Install: pip install "storymesh[langsmith]"
# Set LANGCHAIN_TRACING_V2=true to enable. All LangGraph node spans and
# individual LLM calls (via @_traceable) will appear in the dashboard.
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=storymesh-dev
